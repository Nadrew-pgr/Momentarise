uv sync                                         # Installer les dรฉpendances
uv run alembic upgrade head                     # Appliquer les migrations
uv run python -m src.seed                       # Crรฉer le user de test
uv run uvicorn src.main:app --reload --port 8000  # Lancer l'API
```

